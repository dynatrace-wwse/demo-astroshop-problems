{
  "name": "[Kubernetes]namespace",
  "description": "Add Kubernetes Namespace to Process Group ",
  "rules": [
    {
      "enabled": true,
      "valueFormat": "{ProcessGroup:KubernetesNamespace}",
      "valueNormalization": "Leave text as-is",
      "type": "ME",
      "attributeRule": {
        "entityType": "PROCESS_GROUP",
        "conditions": [
          {
            "key": "CLOUD_APPLICATION_NAMESPACE_NAME",
            "operator": "EXISTS"
          }
        ],
        "pgToHostPropagation": false,
        "pgToServicePropagation": true
      }
    }
  ]
}